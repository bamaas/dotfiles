{
  "name": "bamaas-dotfiles",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    // Optional: raises mise's GitHub API rate limit during build. Export
    // GITHUB_TOKEN on the host (e.g. `export GITHUB_TOKEN=$(gh auth token)`)
    // before `devpod up`. Empty -> anonymous (fine for occasional builds).
    "args": {
      "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
    }
  },
  "remoteUser": "vscode",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerEnv": {
    "DEVCONTAINER": "1",
    // Claude Code auth: long-lived token generated on the host via
    // `claude setup-token`, exported in ~/.zshrc.local (git-ignored). Read from
    // the host env at up-time — no secret is stored in this repo. The macOS
    // Keychain login can't be mounted into a Linux container, so this is the way.
    "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}",
    // One token covers both: mise reads GITHUB_TOKEN (raises its GitHub API
    // limit) and gh reads it too (authenticates the CLI). Sourced from the host
    // env, which your mise secrets.local.toml exports.
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },
  // Fix docker socket GID mismatch: host socket is mounted as root:root but
  // the vscode user's docker group has a different GID.
  "postStartCommand": "sudo chgrp docker /var/run/docker.sock 2>/dev/null || true",
  // Re-apply in case the repo changed since the image was built (no-op otherwise).
  "postCreateCommand": "chezmoi apply --source $HOME/git/dotfiles || true"
}
